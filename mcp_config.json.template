{
  "mcpServers": {
    "markdown-rag": {
      "command": "{{REPO_DIR}}/.venv/bin/python",
      "args": ["{{REPO_DIR}}/mcp_server.py"],
      "env": {
        "RAG_URL": "{{RAG_URL}}",
        "HOST_VAULT_PATH": "{{VAULT_PATH}}",
        "WRITE_VAULT": "{{WRITE_VAULT}}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp",
        "--browser",
        "chrome",
        "--user-data-dir",
        "{{CHROME_PROFILE}}"
      ]
    }
  }
}
